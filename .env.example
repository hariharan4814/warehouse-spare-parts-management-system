# Warehouse Spare Parts Management System - Root Env Template

# ==============================================================================
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# ==============================================================================
# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-in-production-use-a-secure-random-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database Configuration
# Set USE_POSTGRES=True once you have PostgreSQL running
USE_POSTGRES=False
DB_NAME=warehouse_spare_parts
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Cross-Origin Resource Sharing (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# JSON Web Token (JWT) Configurations
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Django REST Framework Settings
API_PAGE_SIZE=20


# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES (frontend/.env.local)
# ==============================================================================
# Public URL for the API Gateway
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
